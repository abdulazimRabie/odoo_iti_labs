<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_hms_patient" model="ir.actions.report">
            <field name="name">Patient Status Report</field>
            <field name="model">hms.patient</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hms.report_patient_status</field>
            <field name="report_file">hms.report_patient_status</field>
            <field name="binding_model_id" ref="model_hms_patient"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_patient_status">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <div class="page" style="font-family: 'Helvetica', Arial, sans-serif; padding: 20px;">

                        <!-- Header with image -->
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px;">
                            <div>
                                <h1 style="color: #2c5aa0; font-size: 32px; font-weight: bold; margin: 0;">Patient Status Report</h1>
                            </div>
                            <div t-if="o.image">
                                <img t-att-src="image_data_uri(o.image)" style="width: 120px; height: 120px; border-radius: 8px; object-fit: cover; border: 2px solid #2c5aa0;"/>
                            </div>
                        </div>

                        <!-- Two column layout -->
                        <div style="display: flex; gap: 40px; margin-bottom: 30px;">
                            <!-- Left Column -->
                            <div style="flex: 1;">
                                <table style="width: 100%; font-size: 14px;">
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555; width: 35%;">Name:</td>
                                        <td style="padding: 8px 0;"><t t-esc="o.first_name"/> <t t-esc="o.last_name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555;">Age:</td>
                                        <td style="padding: 8px 0;"><t t-esc="o.age"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555;">Department:</td>
                                        <td style="padding: 8px 0;"><t t-esc="o.department_id.name or 'N/A'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555;">Doctors:</td>
                                        <td style="padding: 8px 0;">
                                            <t t-if="o.doctor_ids">
                                                <t t-esc="', '.join([(doc.first_name + ' ' + doc.last_name) for doc in o.doctor_ids])"/>
                                            </t>
                                            <t t-if="not o.doctor_ids">N/A</t>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Right Column -->
                            <div style="flex: 1;">
                                <table style="width: 100%; font-size: 14px;">
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555; width: 35%;">Birth Date:</td>
                                        <td style="padding: 8px 0;"><t t-esc="o.birth_date or 'N/A'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555;">PCR:</td>
                                        <td style="padding: 8px 0;"><t t-esc="o.cr_ratio or 'N/A'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555;">Blood Type:</td>
                                        <td style="padding: 8px 0;"><t t-esc="o.blood_type or 'N/A'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0; font-weight: bold; color: #555;">Email:</td>
                                        <td style="padding: 8px 0;"><t t-esc="o.email or 'N/A'"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Log History -->
                        <div style="margin-top: 30px;">
                            <h2 style="color: #2c5aa0; font-size: 20px; border-bottom: 2px solid #2c5aa0; padding-bottom: 8px; margin-bottom: 15px;">Log History</h2>
                            <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
                                <thead>
                                    <tr style="background-color: #2c5aa0; color: white;">
                                        <th style="padding: 10px; text-align: left; border: 1px solid #ddd;">User</th>
                                        <th style="padding: 10px; text-align: left; border: 1px solid #ddd;">Date</th>
                                        <th style="padding: 10px; text-align: left; border: 1px solid #ddd;">Info</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.log_ids" t-as="log">
                                        <tr t-att-style="'background-color: #e3f2fd;' if log_index % 2 == 0 else 'background-color: #ffffff;'">
                                            <td style="padding: 10px; border: 1px solid #ddd;"><t t-esc="log.created_by.name or 'System'"/></td>
                                            <td style="padding: 10px; border: 1px solid #ddd;"><t t-esc="log.date"/></td>
                                            <td style="padding: 10px; border: 1px solid #ddd;"><t t-esc="log.description"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="not o.log_ids">
                                        <tr>
                                            <td colspan="3" style="padding: 10px; border: 1px solid #ddd; text-align: center; color: #888;">No log history available</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </t>
            </t>
        </template>

    </data>
</odoo>
