<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hms_patient_list" model="ir.ui.view">
        <field name="name">hms.patient.list</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <list string="Patients">
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="birth_date"/>
                <field name="age"/>
                <field name="blood_type"/>
                <field name="pcr"/>
                <field name="department_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hms_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>
                    <field name="image" widget="image"
                           class="oe_avatar" options="{'size': [128, 128]}"/>
                    <div class="oe_title">
                        <label for="first_name" string="Patient Name"/>
                        <h1>
                            <field name="first_name" placeholder="First Name"/>
                            <field name="last_name"  placeholder="Last Name"/>
                        </h1>
                    </div>

                    <group>
                        <field name="state" widget="radio" options="{'horizontal': true}"/>
                    </group>

                    <group>
                        <group string="Personal Info">
                            <field name="birth_date"/>
                            <field name="age"/>
                            <field name="address"/>
                        </group>
                        <group string="Medical Info">
                            <field name="blood_type"/>
                            <field name="cr_ratio" required="pcr"/>
                            <field name="pcr"/>
                        </group>
                    </group>

                    <group string="Department Info">
                        <field name="department_id"
                               domain="[('is_opened', '=', True)]"/>
                        <field name="capacity" readonly="1"/>
                        <field name="doctor_ids"
                               widget="many2many_tags"
                               readonly="not department_id"/>
                    </group>

                    <field name="show_history" invisible="1"/>

                    <!-- if age < 50 , history ==> hidden -->
                    <group string="Medical History"
                           invisible="not show_history">
                        <field name="history" nolabel="1"/>
                    </group>

                    <!-- log history  -->
                    <notebook>
                        <page string="Log History">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="created_by"/>
                                    <field name="date"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hms_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_hms_root"
              name="HMS"
              sequence="10"/>

    <menuitem id="menu_hms_patients"
              name="Patients"
              parent="menu_hms_root"
              action="action_hms_patient"
              sequence="10"/>

    <menuitem id="menu_hms_departments"
              name="Departments"
              parent="menu_hms_root"
              action="action_hms_department"
              sequence="20"/>

    <menuitem id="menu_hms_doctors"
                name="Doctors"
                parent="menu_hms_root"
                action="action_hms_doctors"
                sequence="30"/>

</odoo>